# =============================================================================
# LimeSurvey DSFR Suite — Variables d'environnement (production)
# =============================================================================
# Copier ce fichier en .env et adapter les valeurs.
#   cp .env.example .env
# =============================================================================

# --- Base de données ---
DB_USERNAME=limesurvey
DB_PASSWORD=CHANGEME_db_password
MYSQL_ROOT_PASSWORD=CHANGEME_root_password
MYSQL_USER=limesurvey
MYSQL_PASSWORD=CHANGEME_db_password

# --- Administration LimeSurvey ---
ADMIN_USER=admin
ADMIN_PASSWORD=CHANGEME_admin_password
ADMIN_NAME=Administrateur
ADMIN_EMAIL=admin@example.com

# --- URL publique ---
# Le domaine ci-dessous est utilisé par Traefik (labels Host) et par LimeSurvey
# pour générer les URL absolues. Remplacer par votre domaine réel.
PUBLIC_DOMAIN=survey.example.org
PUBLIC_URL=https://survey.example.org

# --- Traefik (topologie spécifique à votre hôte) ---
# Nom du réseau Docker externe partagé avec votre stack Traefik parente.
TRAEFIK_NETWORK=traefik_public
# Nom du certresolver Traefik (défini dans votre config Traefik parente).
TRAEFIK_CERT_RESOLVER=letsencrypt
# Options TLS custom (laisser `default` si vous n'en avez pas).
# Exemples : default, anssi-strict@file, modern@file
TRAEFIK_TLS_OPTIONS=default
# Middleware de sécurité (security headers). Laisser vide si non utilisé.
# Exemples : security-headers@file, csp-strict@file
TRAEFIK_SECURITY_MW=

# --- Chiffrement (générer avec : openssl rand -hex 32) ---
# ENCRYPT_KEYPAIR=
# ENCRYPT_NONCE=
# ENCRYPT_SECRET_BOX_KEY=
